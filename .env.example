# =============================================
# Configuration de l'assistant domotique
# Copier ce fichier en .env et adapter les valeurs
# =============================================

# --- Home Assistant ---
HA_URL=http://maison.local:8123
HA_TOKEN=ton_token_long_lived_ici
MES_PIECES=Salon,Cuisine,Chambre,Cellier,Bureau,Extérieur,Pergola,Serre

# --- Raspberry Pi / Whisper ---
RASPBERRY_PI_IP=maison.local
# WHISPER_URL=  # Si vide, construit automatiquement depuis RASPBERRY_PI_IP

# --- Mode de transcription ---
# "vosk"   → Vosk local temps réel (Linux uniquement, recommandé si pas de Raspberry Pi)
# "remote" → Faster-Whisper sur le Raspberry Pi (meilleure précision)
# "local"  → whisper.cpp en local (si pas de Raspberry Pi)
# Sur Windows → remote ou local automatiquement (Vosk non disponible)
TRANSCRIPTION_MODE=vosk

# --- Chemins whisper.cpp (mode local uniquement) ---
WHISPER_BIN=/home/user/projets/speach/whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL=/home/user/projets/speach/whisper.cpp/models/ggml-base.bin
WHISPER_VAD_MODEL=/home/user/projets/speach/whisper.cpp/models/for-tests-silero-v6.2.0-ggml.bin

# --- Vosk ---
VOSK_MODEL_PATH=/home/user/vosk-model-fr

# --- Audio ---
ALSA_DEVICE=plughw:CARD=Bar,DEV=0
WINDOWS_MIC=Microphone (Realtek(R) Audio)

# --- GSM ---
GSM_PORT=/dev/ttyUSB0
GSM_PIN=1234

# --- Piper ---
PIPER_BIN=/opt/piper/piper
PIPER_MODEL=/opt/piper-voices/fr_FR-siwis-medium.onnx

# --- Notify ---
NOTIFY_DEVICE=

# --- Modem ---
MODEM_URL=http://192.168.1.1
MODEM_PASSWORD=
MODEM_VERIF_KEY=
MODEM_XOR_KEY=
MODEM_FREE_KEY=
MODEM_HMAC_KEY=
WHITELIST=

# --- API HTTP ---
API_PORT=8080
API_KEY=